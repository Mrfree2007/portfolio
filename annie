<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sorry Ananya ❤️</title>

<style>
body{
    margin:0;
    padding:0;
    background:linear-gradient(135deg,#ff416c,#ff4b2b);
    font-family:Arial,sans-serif;
    text-align:center;
    color:white;
    overflow-x:hidden;
}

.container{
    margin-top:50px;
}

h1{
    font-size:60px;
    animation:glow 2s infinite;
}

.heart{
    width:120px;
    height:120px;
    background:red;
    position:relative;
    margin:40px auto;
    transform:rotate(-45deg);
    animation:beat 1s infinite;
}

.heart:before,
.heart:after{
    content:"";
    width:120px;
    height:120px;
    background:red;
    border-radius:50%;
    position:absolute;
}

.heart:before{
    top:-60px;
    left:0;
}

.heart:after{
    left:60px;
    top:0;
}

button{
    padding:15px 30px;
    border:none;
    border-radius:30px;
    font-size:18px;
    cursor:pointer;
    background:white;
    color:#ff416c;
    font-weight:bold;
}

button:hover{
    transform:scale(1.1);
}

.code-box{
    width:80%;
    margin:30px auto;
    text-align:left;
    background:rgba(0,0,0,0.4);
    padding:20px;
    border-radius:15px;
    overflow:auto;
}

pre{
    color:#00ff99;
    white-space:pre-wrap;
}

@keyframes beat{
    0%,100%{transform:rotate(-45deg) scale(1);}
    50%{transform:rotate(-45deg) scale(1.2);}
}

@keyframes glow{
    0%,100%{text-shadow:0 0 10px white;}
    50%{text-shadow:0 0 25px white;}
}
</style>
</head>

<body>

<div class="container">

<h1>I'm Sorry Ananya ❤️</h1>

<div class="heart"></div>

<p id="msg">
Mujhse galti ho gayi... 😔<br>
Tum meri life ka sabse beautiful part ho ❤️
</p>

<br>

<button onclick="forgiveMe()">
Forgive Me 🥺
</button>

<div class="code-box">
<h2>❤️ C Code ❤️</h2>
<pre>
#include &lt;stdio.h&gt;

int main() {
    printf("Sorry Ananya ❤️");
    printf("Please mujhe maaf kar do 🥺");
    return 0;
}
</pre>

<h2>❤️ C++ Code ❤️</h2>
<pre>
#include &lt;iostream&gt;
using namespace std;

int main() {
    cout &lt;&lt; "I Love You Ananya ❤️";
    cout &lt;&lt; "Sorry for my mistake 🥺";
    return 0;
}
</pre>

<h2>❤️ Love Algorithm ❤️</h2>
<pre>
IF (Ananya Angry)
{
    Say Sorry();
    Give Love();
    Hug();
}
ELSE
{
    Stay Happy Forever ❤️
}
</pre>

</div>

</div>

<script>
function forgiveMe(){
    document.getElementById("msg").innerHTML =
    "Thank You Ananya ❤️<br>I Promise I Will Never Hurt You Again 💕🥺";
}
</script>

</body>
</html>
